# ── Quotes Environment Variables ──────────────────────────────────────────────
# Copy to .env.local for local development.
#   cp .env.example .env.local
#
# For production (Vercel), set these as Project Environment Variables
# in the Vercel Dashboard: Settings → Environment Variables

# Public site URL — used for sitemap, canonical URLs, and SEO meta tags.
# Local:   http://localhost:4000
# Production: https://your-domain.com (your actual Vercel deployment domain)
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# ═══════════════════════════════════════════════════════════════════════════════
# Vercel System Variables (injected automatically — do not set manually)
#   VERCEL                  "1"
#   VERCEL_ENV              "production" | "preview" | "development"
#   VERCEL_URL              Deployment URL (e.g. quotes-abc123.vercel.app)
#   NEXT_PUBLIC_VERCEL_URL  Same as VERCEL_URL but public (if needed in client)
# ═══════════════════════════════════════════════════════════════════════════════
